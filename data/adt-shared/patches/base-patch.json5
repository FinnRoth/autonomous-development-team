// Base ADT configuration patch.
// Applied first by scripts/setup.sh before the MCP and agent patches.
// Placeholders are substituted by setup.sh before applying.
{
  gateway: {
    password: '{{OPENCLAW_GATEWAY_PASSWORD}}',
    mode: 'local',
  },
  models: {
    providers: {
      litellm: {
        baseUrl: '{{LITELLM_BASE_URL}}/litellm/v1',
        apiKey: '${LITELLM_API_KEY}',
        api: 'openai-completions',
        models: [
          {
            id: 'anthropic--claude-opus-4-6',
            name: 'Claude Opus 4.6',
            reasoning: true,
            input: ['text', 'image'],
          },
        ],
      },
    },
  },
}
