// default-agent-patch.json5
// Applied via `openclaw config patch --file <this>` after `openclaw agents add`
// has registered each ADT agent. Makes project-lead the user-facing default,
// demotes 'main' from default, opens up subagent delegation across the team,
// and enables agent-to-agent messaging so handoffs are actually delivered via
// `sessions_send` (not just written to outbox files).
{
  agents: {
    list: [
      // 'main' is an OpenClaw seed artifact — kept so runtime state referencing
      // it stays valid, but not the default.
      { id: 'main', default: false },
      // The team's front door.
      { id: 'project-lead', default: true, subagents: { allowAgents: ['*'] } },
      // Every worker can delegate to any other worker.
      { id: 'architect', subagents: { allowAgents: ['*'] } },
      { id: 'backend',   subagents: { allowAgents: ['*'] } },
      { id: 'frontend',  subagents: { allowAgents: ['*'] } },
      { id: 'uiux',      subagents: { allowAgents: ['*'] } },
      { id: 'reviewer',  subagents: { allowAgents: ['*'] } },
      { id: 'qa',        subagents: { allowAgents: ['*'] } },
    ],
  },

  // ── Agent-to-agent messaging ──────────────────────────────────────────────
  // Required so that agents can reach each other via `sessions_send`.
  // Without this, messages only exist as outbox JSON files and are never delivered.
  tools: {
    sessions: {
      visibility: 'all',   // every agent can see every other agent's sessions
    },
    agentToAgent: {
      enabled: true,
      // Explicit allow-list of the 7 ADT agents. 'main' is intentionally excluded.
      allow: ['project-lead', 'architect', 'backend', 'frontend', 'uiux', 'reviewer', 'qa'],
    },
  },
}
