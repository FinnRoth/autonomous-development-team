// adt-mcp-patch.json5
// Patch to be applied via `openclaw config patch --file <this>` inside the container.
// Defines the MCP server fleet and routes each server to specific agents via `codex.agents`.
//
// IDs of installable Node/Python MCP servers used here:
//   - filesystem:           @modelcontextprotocol/server-filesystem (Node, npx)
//   - git:                  uvx mcp-server-git (Python via uvx) — but we use the Node port
//                           '@cyanheads/git-mcp-server' for simpler container ops. Falls back to plain git CLI shell access.
//   - github:               @modelcontextprotocol/server-github (Node, npx) — also works with GH-compatible APIs via GH_HOST env
//   - context7:             @upstash/context7-mcp (Node, npx)
//   - sequential-thinking:  @modelcontextprotocol/server-sequential-thinking (Node, npx)
//   - playwright:           @playwright/mcp (Node, npx) — uses local Chromium
//   - figma:                figma-developer-mcp (Node, npx) — reads FIGMA_TOKEN
//
// Tokens come from the container env (docker-compose.yml). The agent-scoping happens through
// `codex.agents`: only those agent ids see the server.
//
// All servers run on-demand (stdio) inside the container; no extra ports needed.
{
  mcp: {
    servers: {
      // ─────────── filesystem (per-agent scope) ───────────
      // Each agent gets a filesystem server scoped strictly to its own workspace.
      // The OpenClaw projection layer (codex.agents) ensures only that agent sees it.
      'fs-project-lead': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@modelcontextprotocol/server-filesystem', '/home/node/.openclaw/workspace-project-lead'],
        codex: { agents: ['project-lead'] },
      },
      'fs-architect': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@modelcontextprotocol/server-filesystem', '/home/node/.openclaw/workspace-architect'],
        codex: { agents: ['architect'] },
      },
      'fs-backend': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@modelcontextprotocol/server-filesystem', '/home/node/.openclaw/workspace-backend'],
        codex: { agents: ['backend'] },
      },
      'fs-uiux': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@modelcontextprotocol/server-filesystem', '/home/node/.openclaw/workspace-uiux'],
        codex: { agents: ['uiux'] },
      },
      'fs-frontend': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@modelcontextprotocol/server-filesystem', '/home/node/.openclaw/workspace-frontend'],
        codex: { agents: ['frontend'] },
      },
      'fs-reviewer': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@modelcontextprotocol/server-filesystem', '/home/node/.openclaw/workspace-reviewer'],
        codex: { agents: ['reviewer'] },
      },
      'fs-qa': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@modelcontextprotocol/server-filesystem', '/home/node/.openclaw/workspace-qa'],
        codex: { agents: ['qa'] },
      },

      // ─────────── context7 (shared by knowledge-heavy agents) ───────────
      context7: {
        enabled: true,
        command: 'npx',
        args: ['-y', '@upstash/context7-mcp'],
        codex: { agents: ['architect', 'backend', 'frontend', 'qa', 'reviewer', 'uiux', 'project-lead'] },
      },

      // ─────────── sequential-thinking (decomposition aid for PL/Architect) ───────────
      'sequential-thinking': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@modelcontextprotocol/server-sequential-thinking'],
        codex: { agents: ['project-lead', 'architect'] },
      },

      // ─────────── figma — rw for uiux, ro for frontend ───────────
      // figma-developer-mcp uses FIGMA_API_KEY env. We split it into two server defs so the toolFilter
      // can drop write tools for frontend.
      'figma-uiux': {
        enabled: true,
        command: 'npx',
        args: ['-y', 'figma-developer-mcp', '--stdio'],
        env: { FIGMA_API_KEY: '${FIGMA_TOKEN}' },
        codex: { agents: ['uiux'] },
      },
      'figma-frontend': {
        enabled: true,
        command: 'npx',
        args: ['-y', 'figma-developer-mcp', '--stdio'],
        env: { FIGMA_API_KEY: '${FIGMA_TOKEN}' },
        codex: { agents: ['frontend'] },
        // Heuristic readonly filter — figma-developer-mcp exposes only read tools today, but be explicit.
        toolFilter: {
          include: ['get_*', 'list_*', 'read_*', 'fetch_*', 'get-figma-data', 'download_*', 'get_image*'],
        },
      },

      // ─────────── playwright — QA's main weapon; frontend optional ───────────
      'playwright-qa': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@playwright/mcp@latest', '--browser', 'chromium'],
        codex: { agents: ['qa'] },
      },
      'playwright-frontend': {
        enabled: true,
        command: 'npx',
        args: ['-y', '@playwright/mcp@latest', '--browser', 'chromium'],
        codex: { agents: ['frontend'] },
      },

      // ─────────── git host: USE gh CLI VIA SHELL EXEC ───────────
      // We deliberately do NOT wire a github MCP server here:
      //   - @modelcontextprotocol/server-github is deprecated/unsupported.
      //   - github/github-mcp-server (the official Go replacement) has no npx package.
      // Instead, every code-touching agent invokes `gh` (or `glab`/`tea` per GIT_HOST_CLI env)
      // via its built-in shell-exec tool, authenticated by the GIT_HOST_TOKEN env var.
      // This keeps the team host-agnostic (GitHub, Gitea, Forgejo, GitLab) per CONVENTIONS.md §2.
    },
  },
}
