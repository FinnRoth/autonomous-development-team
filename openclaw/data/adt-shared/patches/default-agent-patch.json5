// default-agent-patch.json5
// Applied via `openclaw config patch --file <this>` after `openclaw agents add`
// has registered each ADT agent. This patch:
//   1. Rewrites `agents.list` with the full 8-entry team (main demoted, 7 ADT
//      agents as first-class members). Because the patch tool REPLACES arrays
//      wholesale (recursive-merge only on objects), every agent entry has to
//      carry all of its fields — otherwise the previously-added workspace/
//      agentDir/model values are wiped.
//   2. Enables OpenClaw agent-to-agent messaging so project-lead can send a
//      contentless WAKE NUDGE to a sleeping worker (prompting it to run its
//      heartbeat and poll board_get_unread sooner). Message CONTENT never
//      travels this way — all agent-to-agent messages are board-api ticket
//      comments (CONVENTIONS.md §4/§12). sessions_send carries no payload.
{
  agents: {
    list: [
      // 'main' is an OpenClaw seed artifact — kept so runtime state referencing
      // it stays valid, but not the default and not part of the workflow.
      {
        id: 'main',
        default: false,
      },

      // ── The team's front door ──────────────────────────────────────────────
      {
        id: 'project-lead',
        name: 'project-lead',
        workspace: '/home/node/.openclaw/workspace-project-lead',
        agentDir: '/home/node/.openclaw/agents/project-lead/agent',
        model: 'litellm/anthropic--claude-opus-4-6',
        default: true,
        subagents: { allowAgents: ['*'] },
      },

      // ── Workers ────────────────────────────────────────────────────────────
      {
        id: 'architect',
        name: 'architect',
        workspace: '/home/node/.openclaw/workspace-architect',
        agentDir: '/home/node/.openclaw/agents/architect/agent',
        model: 'litellm/anthropic--claude-opus-4-6',
        subagents: { allowAgents: ['*'] },
      },
      {
        id: 'backend',
        name: 'backend',
        workspace: '/home/node/.openclaw/workspace-backend',
        agentDir: '/home/node/.openclaw/agents/backend/agent',
        model: 'litellm/anthropic--claude-opus-4-6',
        subagents: { allowAgents: ['*'] },
      },
      {
        id: 'frontend',
        name: 'frontend',
        workspace: '/home/node/.openclaw/workspace-frontend',
        agentDir: '/home/node/.openclaw/agents/frontend/agent',
        model: 'litellm/anthropic--claude-opus-4-6',
        subagents: { allowAgents: ['*'] },
      },
      {
        id: 'uiux',
        name: 'uiux',
        workspace: '/home/node/.openclaw/workspace-uiux',
        agentDir: '/home/node/.openclaw/agents/uiux/agent',
        model: 'litellm/anthropic--claude-opus-4-6',
        subagents: { allowAgents: ['*'] },
      },
      {
        id: 'reviewer',
        name: 'reviewer',
        workspace: '/home/node/.openclaw/workspace-reviewer',
        agentDir: '/home/node/.openclaw/agents/reviewer/agent',
        model: 'litellm/anthropic--claude-opus-4-6',
        subagents: { allowAgents: ['*'] },
      },
      {
        id: 'qa',
        name: 'qa',
        workspace: '/home/node/.openclaw/workspace-qa',
        agentDir: '/home/node/.openclaw/agents/qa/agent',
        model: 'litellm/anthropic--claude-opus-4-6',
        subagents: { allowAgents: ['*'] },
      },
    ],
  },

  // ── Agent-to-agent messaging (WAKE NUDGE ONLY) ────────────────────────────
  // Retained so project-lead can nudge a sleeping agent to run its heartbeat.
  // Message CONTENT is always a board-api comment (CONVENTIONS.md §4) — a nudge
  // carries no payload. Without this, a newly-assigned urgent ticket would wait
  // until the worker's next scheduled heartbeat.
  tools: {
    sessions: {
      visibility: 'all',   // every agent can see every other agent's sessions
    },
    agentToAgent: {
      enabled: true,
      // Explicit allow-list of the 7 ADT agents. 'main' is intentionally excluded.
      // Used only for wake nudges — not for message delivery (see note above).
      allow: ['project-lead', 'architect', 'backend', 'frontend', 'uiux', 'reviewer', 'qa'],
    },
  },
}
