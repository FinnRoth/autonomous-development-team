# ─── OS / editor cruft ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# ─── Node ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ─── ADT generated files (created by scripts/setup.sh) ─────────────
docker-compose.yml
.setup-logs/

# ─── ADT runtime state (everything under data/ that is NOT template) ─
# Pattern: default-deny data/, re-include template pieces, re-exclude runtime
# state that lands inside re-included workspaces.

/openclaw/data/**

# Re-include template: shared config + all agent workspaces
!/openclaw/data/adt-shared/
!/openclaw/data/adt-shared/**
!/openclaw/data/workspace-*/
!/openclaw/data/workspace-*/**

# Re-exclude runtime state inside workspaces
/openclaw/data/workspace-*/.git/
/openclaw/data/workspace-*/.openclaw/
/openclaw/data/workspace-*/openclaw-workspace-state.json
/openclaw/data/workspace-*/memory/*.md
/openclaw/data/workspace-*/MEMORY.md
/openclaw/data/workspace-project-lead/USER.md
/openclaw/data/workspace-*/inbox/*
/openclaw/data/workspace-*/outbox/*
/openclaw/data/workspace-*/code/*
/openclaw/data/workspace-*/docs/*
/openclaw/data/workspace-*/misc/*

# Re-exclude workspace-attestations runtime dir, that was included by !/openclaw/data/workspace-*/
/openclaw/data/workspace-attestations/

# Restore sentinels
!/openclaw/data/workspace-*/memory/.gitkeep
!/openclaw/data/workspace-*/inbox/.gitkeep
!/openclaw/data/workspace-*/outbox/.gitkeep
!/openclaw/data/workspace-*/code/.gitkeep
!/openclaw/data/workspace-*/docs/.gitkeep
!/openclaw/data/workspace-*/misc/.gitkeep

# board-api Python artifacts
board-api/__pycache__/
board-api/*.pyc
board-api/.pytest_cache/
