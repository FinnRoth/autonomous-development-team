# ─── OS / editor cruft ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# ─── Node ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ─── ADT runtime state (everything under data/ that is NOT template) ─
# Pattern: default-deny data/, re-include template pieces, re-exclude runtime
# state that lands inside re-included workspaces.

/data/**

# Re-include template: shared config + all agent workspaces
!/data/adt-shared/
!/data/adt-shared/**
!/data/workspace-*/
!/data/workspace-*/**

# Re-exclude runtime state inside workspaces
/data/workspace-*/.git/
/data/workspace-*/.openclaw/
/data/workspace-*/openclaw-workspace-state.json
/data/workspace-*/memory/*.md
/data/workspace-*/MEMORY.md
!/data/workspace-*/USER.md
/data/workspace-project-lead/USER.md
/data/workspace-*/inbox/*
/data/workspace-*/outbox/*
/data/workspace-*/code/*
/data/workspace-*/docs/*
/data/workspace-*/misc/*

# Re-exclude workspace-attestations runtime dir, that was included by !/data/workspace-*/
/data/workspace-attestations/

# Restore sentinels
!/data/workspace-*/memory/.gitkeep
!/data/workspace-*/inbox/.gitkeep
!/data/workspace-*/outbox/.gitkeep
!/data/workspace-*/code/.gitkeep
!/data/workspace-*/docs/.gitkeep
!/data/workspace-*/misc/.gitkeep
